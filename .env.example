# ===========================================
# Music Agent - Настройки
# ===========================================

# База данных (sqlite, postgres, mysql)
MUSIC_AGENT_DB_TYPE=sqlite
MUSIC_AGENT_DB_CONN=music_agent.db

# Хранилище файлов (local, s3, telegram)
MUSIC_AGENT_FS_TYPE=local
MUSIC_AGENT_FS_CONN=./storage

# ===========================================
# Poe API (обязательно для переводов и обложек)
# Получить ключ: https://poe.com/api_key
# ===========================================
MUSIC_AGENT_POE_API_KEY=your_poe_api_key_here
MUSIC_AGENT_POE_TRANSLATION_MODEL=Claude-Opus-4.6
MUSIC_AGENT_POE_COVER_MODEL=Nano-Banana-Pro

# ===========================================
# Suno (cookie из браузера)
# ===========================================
MUSIC_AGENT_SUNO_COOKIE=session=abc123;...
MUSIC_AGENT_SUNO_ACCOUNT=grandemotions

# ===========================================
# Голосовые команды (Deepgram)
# ===========================================
MUSIC_AGENT_VOICE_API_KEY=
MUSIC_AGENT_VOICE_MODEL=nova-2

# ===========================================
# Дистрибьюторы (cookies)
# ===========================================
MUSIC_AGENT_ROUTENOTE_COOKIE=
MUSIC_AGENT_SFEROOM_COOKIE=

# ===========================================
# Telegram Bot (опционально)
# ===========================================
MUSIC_AGENT_TELEGRAM_BOT_TOKEN=your_bot_token_here
MUSIC_AGENT_TELEGRAM_ADMIN_IDS=your_telegram_id_here

# ===========================================
# Дополнительно
# ===========================================
MUSIC_AGENT_DEBUG=false
MUSIC_AGENT_PROXY=
MUSIC_AGENT_LOG_LEVEL=INFO
